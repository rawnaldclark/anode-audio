<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Audio input permission for guitar signal capture -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Foreground service permission to keep audio processing alive -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Notification permission required on Android 13+ (API 33) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- WakeLock permission to prevent CPU sleep during audio processing -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Request battery optimization exemption (user-prompted, not automatic) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Declare microphone feature as not strictly required so the app can still
         be installed on devices without a mic (e.g., tablets using USB audio) -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />

    <application
        android:name=".GuitarEmulatorApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GuitarEmulator">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize|uiMode"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service for continuous audio processing.
             Uses mediaPlayback type so the system allows sustained audio I/O. -->
        <service
            android:name=".audio.AudioProcessingService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback|microphone" />

    </application>

</manifest>
